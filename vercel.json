{
  "version": 2,
  "name": "hospital-management-system",
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*).(js|css|png|jpg|svg|html|webp)",
      "dest": "client/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}
